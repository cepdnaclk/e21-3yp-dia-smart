# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=diasmart
PGUSER=diasmart_app
PGPASSWORD=change_this_password

# Backend server
PORT=3000
NODE_ENV=development
GLUCO_FILE_ONLY=false

# Browser/frontend access
CORS_ORIGIN=http://localhost:3000

# Optional MQTT bridge
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_TOPIC_PREFIX=diasmart